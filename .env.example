# API配置
API_KEY=your-secret-api-key-change-this
PORT=8000
HOST=0.0.0.0

# 浏览器配置
HEADLESS=true
BROWSER_TIMEOUT=60000
BROWSER_SLOW_MO=0
BROWSER_LOCALE=zh-CN
BROWSER_TIMEZONE=UTC
BROWSER_USER_AGENT=

# 会话配置
COOKIE_FILE=./data/cookies.json
STATE_FILE=./data/storage-state.json
SESSION_REFRESH_INTERVAL=1800
SESSION_TTL_CHECK_INTERVAL=300
HANDOFF_ENABLED=true
NOVNC_BASE_URL=http://localhost:6080/vnc.html?autoconnect=true&resize=remote

# 重试配置
MAX_RETRIES=3
RETRY_DELAY=5

# 日志
LOG_LEVEL=INFO
